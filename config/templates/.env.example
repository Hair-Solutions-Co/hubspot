# HubSpot workspace secrets only.
# Copy to `.env` locally and fill with real values via 1Password-backed injection.
# Do not store HubSpot CLI profile auth, OAuth auth codes, or per-user session tokens here.

# -----------------------------------------------------------------------------
# HubSpot private-app tokens (use-case scoped)
# -----------------------------------------------------------------------------
HUBSPOT_PRIVATE_APP__OPS__ACCESS_TOKEN="your-hubspot-private-app-ops-token"
HUBSPOT_PRIVATE_APP__CRM_SCHEMA__ACCESS_TOKEN="your-hubspot-private-app-crm-schema-token"
HUBSPOT_PRIVATE_APP__HUBDB__ACCESS_TOKEN="your-hubspot-private-app-hubdb-token"
HUBSPOT_PRIVATE_APP__CMS__ACCESS_TOKEN="your-hubspot-private-app-cms-token"
HUBSPOT_PRIVATE_APP__CONTENT__ACCESS_TOKEN="your-hubspot-private-app-content-token"

# -----------------------------------------------------------------------------
# HubSpot developer app credentials (project scoped)
# -----------------------------------------------------------------------------
HUBSPOT_APP__UI_CARDS__CLIENT_ID="your-hubspot-ui-cards-client-id"
HUBSPOT_APP__UI_CARDS__CLIENT_SECRET="your-hubspot-ui-cards-client-secret"
HUBSPOT_APP__UI_CARDS__STATIC_ACCESS_TOKEN="your-hubspot-ui-cards-static-access-token"

HUBSPOT_APP__CUSTOMER_PORTAL__CLIENT_ID="your-hubspot-customer-portal-client-id"
HUBSPOT_APP__CUSTOMER_PORTAL__CLIENT_SECRET="your-hubspot-customer-portal-client-secret"
HUBSPOT_APP__CUSTOMER_PORTAL__STATIC_ACCESS_TOKEN="your-hubspot-customer-portal-static-access-token"

HUBSPOT_APP__PROGRAMMABLE_EMAILS__CLIENT_ID="your-hubspot-programmable-emails-client-id"
HUBSPOT_APP__PROGRAMMABLE_EMAILS__CLIENT_SECRET="your-hubspot-programmable-emails-client-secret"
HUBSPOT_APP__PROGRAMMABLE_EMAILS__STATIC_ACCESS_TOKEN="your-hubspot-programmable-emails-static-access-token"

HUBSPOT_APP__CRM_OBJECT_SYNC__CLIENT_ID="your-hubspot-crm-object-sync-client-id"
HUBSPOT_APP__CRM_OBJECT_SYNC__CLIENT_SECRET="your-hubspot-crm-object-sync-client-secret"
HUBSPOT_APP__CRM_OBJECT_SYNC__STATIC_ACCESS_TOKEN="your-hubspot-crm-object-sync-static-access-token"

HUBSPOT_APP__ASSOCIATIONS_SYNC__CLIENT_ID="your-hubspot-associations-sync-client-id"
HUBSPOT_APP__ASSOCIATIONS_SYNC__CLIENT_SECRET="your-hubspot-associations-sync-client-secret"
HUBSPOT_APP__ASSOCIATIONS_SYNC__STATIC_ACCESS_TOKEN="your-hubspot-associations-sync-static-access-token"

HUBSPOT_APP__PROPERTY_MAPPING__CLIENT_ID="your-hubspot-property-mapping-client-id"
HUBSPOT_APP__PROPERTY_MAPPING__CLIENT_SECRET="your-hubspot-property-mapping-client-secret"
HUBSPOT_APP__PROPERTY_MAPPING__STATIC_ACCESS_TOKEN="your-hubspot-property-mapping-static-access-token"

# -----------------------------------------------------------------------------
# Cross-project app secrets surfaced in current HubSpot workspace projects
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/hubspot_workspace"
NEXTAUTH_SECRET="generate-a-random-32-byte-secret"

STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

SHOPIFY_ADMIN_API_TOKEN="shpat_replace_me"
SHOPIFY_WEBHOOK_SECRET="replace-shopify-webhook-secret"

NOTION_API_KEY="ntn_replace_me"

SMTP_USER="noreply@example.com"
SMTP_PASSWORD="replace-smtp-password"

OPENAI_API_KEY="sk-replace-me"
ANTHROPIC_API_KEY="sk-ant-replace-me"

SUPABASE_SECRET_KEY="sb_secret_replace_me"
SUPABASE_ANON_KEY="sb_anon_replace_me"
SUPABASE_DB_PASSWORD="replace-supabase-db-password"

JWT_SECRET_KEY="replace-jwt-secret"
GITHUB_TOKEN="ghp_replace_me"
HOSTINGER_API_KEY="replace-hostinger-api-key"

CLOUDINARY_API_KEY="replace-cloudinary-api-key"
CLOUDINARY_API_SECRET="replace-cloudinary-api-secret"

CLICKUP_CLIENT_SECRET="replace-clickup-client-secret"
CLICKUP_ACCESS_TOKEN="replace-clickup-access-token"
CLICKUP_OAUTH_CODE="replace-clickup-oauth-code-if-needed"

GOOGLE_CLIENT_SECRET="replace-google-client-secret"
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@example.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_CLIENT_ID="replace-google-service-account-client-id"

ELEVENLABS_API_KEY="replace-elevenlabs-api-key"
HEYGEN_API_KEY="replace-heygen-api-key"
YOUTUBE_REFRESH_TOKEN="replace-youtube-refresh-token"

PUBLISH_API_KEY="replace-publish-api-key"
NOTION_TOKEN="replace-notion-token-if-needed"
OP_SERVICE_ACCOUNT_TOKEN="replace-1password-service-account-token"
OP_SSH_PRIVATE_KEY="replace-op-ssh-private-key-only-if-required"