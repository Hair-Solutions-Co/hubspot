# Non-secret defaults for the HubSpot workspace boundary.
# Keep secrets in the 1Password-backed .env link, not in this file.

HUBSPOT_ENV_BOUNDARY=hubspot
HUBSPOT_WORKSPACE_ROOT=/Users/vMac/00-hair-solutions-co/00-engineering/hubspot

# -----------------------------------------------------------------------------
# HubSpot account metadata and local defaults (non-secret)
# -----------------------------------------------------------------------------
HUBSPOT_ACCOUNT__PRIMARY__PORTAL_ID=00000000
