HUBSPOT_ACCOUNT__SANDBOX__CLI_ACCOUNT_NAME=sandbox

# -----------------------------------------------------------------------------
# HubSpot developer app metadata (project scoped, non-secret)
# -----------------------------------------------------------------------------
