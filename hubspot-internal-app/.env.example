# ─────────────────────────────────────────────────────────────
# HubSpot App — Environment Variables
# Reference variable names only.
# In this workspace, real secrets belong in 1Password Desktop Environments and
# should be injected into the process rather than written into a local .env file.
# ─────────────────────────────────────────────────────────────

# ── HubSpot ─────────────────────────────────────────────────
# Your HubSpot portal ID (found in account settings -> account info)
HUBSPOT_PORTAL_ID=

# App credentials — from your app's Auth settings in the developer portal
HUBSPOT_APP_ID=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Optional static token for standard CRM/private-app usage
HUBSPOT_ACCESS_TOKEN=

# Optional: separate broad-scope service key for admin/automation scripts
HUBSPOT_SERVICE_KEY=

# Optional: developer-portal API key for developer account operations
HUBSPOT_DEVELOPER_API_KEY=

# After the OAuth flow completes, your server will receive and store these
HUBSPOT_REFRESH_TOKEN=

# ── OAuth / Server ───────────────────────────────────────────
# Base URL where this app is running (used to construct redirect URLs)
APP_BASE_URL=http://localhost:3000

# OAuth callback path (must match redirectUrls in app-hsmeta.json)
OAUTH_REDIRECT_PATH=/oauth/callback

# ── Shopify ─────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=one-head-hair.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_STOREFRONT_API_TOKEN=

# ── ClickUp ─────────────────────────────────────────────────
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=

# ── Notion ──────────────────────────────────────────────────
NOTION_INTEGRATION_TOKEN=
NOTION_WORKSPACE_ID=

# ── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Misc ────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
